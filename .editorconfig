# EditorConfig helps maintain consistent coding styles across editors
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,json,md}]
max_line_length = 100

[*.md]
trim_trailing_whitespace = false  # preserve intentional line breaks in markdown

.gitignore
editorconfig = false
