# Cauldron OS environment variables (copy to .env for your own overrides).
# NOTE: the app reads these from the process environment; it does not auto-load
# a .env file today. Export them, or use your own loader.
# API keys (OpenAI/Gemini) are NOT set here — enter them in the UI Settings.

# HTTP port the server listens on.
PORT=3000

# Host interface to bind. Defaults to loopback; set 0.0.0.0 for LAN access.
CAULDRON_HOST=127.0.0.1

# Local Ollama endpoint for local model generation.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Token budgets for generation stages.
CAULDRON_CLARIFY_NUM_PREDICT=2048
CAULDRON_BLUEPRINT_NUM_PREDICT=8192

# Directory for local runtime data (drafts, sql.js DB, research assets).
CAULDRON_DATA_DIR=./data

# Set to 1 to disable remote community-catalog fetches (offline mode).
CAULDRON_COMMUNITY_OFFLINE=0

# Minimum number of design systems expected by the validation script.
CAULDRON_MIN_DESIGN_SYSTEMS=150

# Optional open-design reference source used by import scripts.
# OPEN_DESIGN_REF=
